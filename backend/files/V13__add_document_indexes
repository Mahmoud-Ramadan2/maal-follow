-- V13: Add indexes for file_document table for better query performance

-- Index for entity type and entity id lookups
CREATE INDEX idx_document_entity ON file_document (entity_type, entity_id);

-- Index for uploaded_by user lookups
CREATE INDEX idx_document_uploaded_by ON file_document (uploaded_by);

-- Index for file type lookups
CREATE INDEX idx_document_file_type ON file_document (file_type);

-- Index for uploaded_at date range queries
CREATE INDEX idx_document_uploaded_at ON file_document (uploaded_at);

